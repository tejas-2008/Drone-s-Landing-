<?xml version="1.0"?>
<launch>
  <!-- Minimal launch file for platform IBVS -->
  <!-- Default params are loaded from config/platform_ibvs_params.yaml.      -->
  <!-- Use the args below to override individual values at the command line:   -->
  <!--   roslaunch dynamic_ibvs minimal.launch marker_id:=5 takeoff_altitude:=3.0 -->

  <node
    pkg="dynamic_ibvs"
    type="platform_ibvs_node"
    name="platform_ibvs"
    output="screen"
  >
    <!-- Load all default parameters from the YAML file -->
    <rosparam
      file="$(find dynamic_ibvs)/config/platform_ibvs_params.yaml"
      command="load"
    />

    <remap from="cmd_vel" to="/mavlink/set_velocity/cmd_vel" />



  </node>

</launch>
